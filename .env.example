# ===========================================
# ASAP KR-Sync Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# Environment
# -------------------------------------------
NODE_ENV=development

# -------------------------------------------
# Server
# -------------------------------------------
# PORT — the port the backend listens on INSIDE the container (or on bare
# metal). Default 3000. Don't change this for the docker-compose flow;
# change APP_PORT below to remap on the host side.
PORT=3000

# APP_PORT — the host-side port the backend is exposed on under
# docker-compose. Override when port 3000 is already taken on your machine
# (e.g., another local app). Container internal port stays 3000 regardless.
# Free choices: 3030, 8080, 8000 — avoid 3001 (used by the markitdown
# profile) and 5432 (postgres).
APP_PORT=3000

# VITE_HOST_PORT — host-side port for the Vite dev server. Default 5173.
VITE_HOST_PORT=5173

# API_BASE_URL — public URL of the backend, used to build Auth0 callback
# URLs and any browser-facing absolute API URLs. MUST match the host port
# you exposed via APP_PORT. If you set APP_PORT=3030, set
# API_BASE_URL=http://localhost:3030.
API_BASE_URL=http://localhost:3000

# FRONTEND_URL — public URL of the Vite dev server (Auth0 post-login
# redirect target, CORS allow-list). Match VITE_HOST_PORT.
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asap_krsync_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# Set DATABASE_SSL=true for managed Postgres (RDS, Aurora, etc.). Local dev
# leaves it off.
DATABASE_SSL=false
# When SSL is on, defaults to verifying the server certificate. Set to
# 'false' only if your managed-DB provider uses self-signed certs.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET=dev_secret_change_this_in_production
# Access-token lifetime: short (15m) so role/permission changes and Auth0
# block actions propagate within one refresh cycle. The frontend axios
# layer auto-refreshes silently on 401 — users never see the boundary.
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# Account Creation
# -------------------------------------------
# Self-service signup gate. When 'false' (default), the public
# POST /api/auth/register endpoint is rejected with 403 and the "Register"
# link is hidden in the UI. Accounts can still be created by an admin via
# POST /api/users, or automatically on first Auth0 login.
# Set to 'true' to allow anyone to register from the login page.
SIGNUP_ENABLED=false

# -------------------------------------------
# Auth0 (ASAP Hub Identity Provider)
# -------------------------------------------
# Set to 'true' to enable ASAP Hub login (requires credentials below).
#
# In production/staging on EC2, the AUTH0_* credentials below are loaded
# from AWS Secrets Manager via AUTH0_SECRET_ID (set in the systemd unit).
# When AUTH0_SECRET_ID is set, these .env values are overridden by the
# values fetched from Secrets Manager. For local dev, leave AUTH0_SECRET_ID
# unset and provide values directly here.
#
# AUTH0_SECRET_ID=asap-kr-sync/dev/auth0   # only set in EC2 systemd unit
AUTH0_ENABLED=false

# Auth0 application credentials (provisioned by ASAP — see the Auth0
# integration guide for the values to fill in). In EC2 these are loaded
# from AWS Secrets Manager via AUTH0_SECRET_ID; for local dev fill them in
# here. Leaving them blank with AUTH0_ENABLED=false keeps Auth0 disabled.
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Re-check Auth0 user status (blocked/deleted) on every token refresh so
# disable/delete actions propagate within ~15 min (one access-token cycle,
# matching JWT_EXPIRES_IN) instead of waiting for the refresh token to
# expire. Adds 100-300ms per refresh. Defaults to 'true' (secure default);
# set to 'false' only if the latency is unacceptable.
AUTH0_VERIFY_ON_REFRESH=true

# Debug helper for the Auth0 integration. When 'true', each verified ID token
# logs its claim NAMES plus values with PII masked (email/name/sub redacted;
# custom/namespaced claims such as a role claim are shown in full). Use this to
# discover which claim Auth0 puts the role in and what shape it has, then turn
# it back off. Safe to enable temporarily in any environment. Defaults to off.
AUTH0_DEBUG_CLAIMS=false

# -------------------------------------------
# AWS S3 Storage
# -------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=asap-kr-sync
S3_BUCKET_PREFIX=dev/
# S3-compatible endpoint override. Required for MinIO local dev (point at
# http://localhost:9000); leave unset for real AWS S3.
S3_ENDPOINT=

# -------------------------------------------
# Python subprocesses
# -------------------------------------------
# Used by the MarkItDown PDF→Markdown converter and the langextract
# datasets-detection helper. Must point at a Python 3 binary that has the
# `markitdown` and `langextract` packages installed. Defaults to `python3`.
PYTHON_BIN=python3

# ===========================================
# Background process state machine
# ===========================================
#
# Every background process (DAS, software, datasets, materials, protocols,
# markdown, pdf_analysis, orcid) goes through the SAME workflow. Two flags
# per process control its behaviour:
#
#   <PROCESS>_ENABLED=true|false             — call the external service?
#   <PROCESS>_DEMO_DATA_ENABLED=true|false   — fall back to demo data?
#
# These two flags produce three CONFIG states (the "On / Demo / Off" pill in
# the UI):
#
#   ENABLED=true                              → On    (external is the source;
#                                                       demo is a final-attempt fallback)
#   ENABLED=false, DEMO_DATA_ENABLED=true     → Demo  (demo is the only source)
#   ENABLED=false, DEMO_DATA_ENABLED=false    → Off   (process produces no data)
#
# After a run, every process resolves to one of two OUTCOME states (the
# "Done / Fail" pill):
#
#   Done = external returned (even empty), OR demo data was found
#   Fail = external errored after all retries AND no demo data is available
#          for this manuscript (or no demo path was enabled)
#
# Note: Demo fallback only fires after pg-boss retries are exhausted —
# transient external errors retry the real service first.
#
# Note: "DEMO_DATA_ENABLED=true" doesn't guarantee Done. The demo data file
# only contains entries for some manuscripts; for others, an enabled-but-
# missing demo lookup yields Fail with an explicit "no demo data for this
# manuscript" message.
#
# Defaults below are intentional: real external services default to disabled
# (you opt them in by setting an API key) but most demo paths default on so
# the app is usable out-of-the-box.

# -------------------------------------------
# PDF Analysis LM API
# -------------------------------------------
# PDF Analysis is now the in-app KRT consolidator (merges every detection's
# items into the Generated KRT). It has no external API call, so the *_ENABLED
# flag defaults to true. The API_BASE_URL / API_KEY / TIMEOUT entries are
# vestigial and unused — kept here only so existing .env files don't error.
PDF_ANALYSIS_ENABLED=true
PDF_ANALYSIS_API_BASE_URL=
PDF_ANALYSIS_API_KEY=
PDF_ANALYSIS_API_TIMEOUT=300000
PDF_ANALYSIS_DEMO_DATA_ENABLED=false
# Suppress specific AI suggestion kinds. Comma-separated tokens, each
# <action>[:<column>[:<state>]]:
#   action: add | edit | update              (update is an alias of edit)
#   column: source | identifier | resourceName     (omit = any column)
#   state:  empty | filled    (the user's CURRENT value in that cell; omit = any)
# Examples:
#   add                      -> drop all "add row" suggestions
#   update:resourceName      -> drop edits that rename an existing row
#   update:source            -> drop ALL SOURCE edits
#   update:source:filled     -> drop SOURCE edits only when the cell already has
#                               a value (don't overwrite); still fill an empty one
#   update:identifier:empty  -> drop IDENTIFIER edits only when the cell is empty
# DEFAULT (when unset/blank): "update:resourceName,update:source:filled" -> no
# name-change suggestions on existing rows, and never overwrite a SOURCE the user
# filled in. A value REPLACES the default. Use "none" to suppress nothing.
PDF_ANALYSIS_SUPPRESS_SUGGESTIONS=update:resourceName,update:source:filled

# -------------------------------------------
# DAS Extraction (Google Gemini)
# Reads the converted markdown (Markdown Convert job) and asks Gemini to
# copy the requested section verbatim. Replaces the Modal-hosted Llama
# fine-tune endpoint (the legacy PDF_DAS_EXTRACTOR_* vars are gone).
# -------------------------------------------
DAS_EXTRACTION_ENABLED=true
DAS_EXTRACTION_GEMINI_API_KEY=your_api_key
DAS_EXTRACTION_GEMINI_MODEL=gemini-2.5-flash
DAS_EXTRACTION_API_TIMEOUT=120000
# Section types: das (default), funding_statement, patient_informed_consent_statement,
# ethics_statement, author_contributions, acknowledgements, coi_statement, keywords.
DAS_EXTRACTION_SECTION=das
DAS_EXTRACTION_DEMO_DATA_ENABLED=true

# -------------------------------------------
# PDF-to-Markdown Conversion
# -------------------------------------------
PDF_MARKDOWN_PROVIDER=modal
PDF_MARKDOWN_MODAL_API_URL=
PDF_MARKDOWN_MODAL_API_KEY=
PDF_MARKDOWN_MODAL_CONVERTER=docling
PDF_MARKDOWN_TIMEOUT=120000
PDF_MARKDOWN_ENABLED=false
PDF_MARKDOWN_DEMO_DATA_ENABLED=true

# -------------------------------------------
# Datasets Detection (Google Gemini + LangExtract)
# -------------------------------------------
DATASETS_DETECTION_ENABLED=false
DATASETS_DETECTION_GEMINI_API_KEY=your_gemini_api_key
DATASETS_DETECTION_GEMINI_MODEL=gemini-2.5-flash
DATASETS_DETECTION_API_TIMEOUT=300000
DATASETS_DETECTION_DEMO_DATA_ENABLED=true
DATASETS_LANGEXTRACT_MAX_WORKERS=60
DATASETS_LANGEXTRACT_MAX_CHAR_BUFFER=3000
DATASETS_LANGEXTRACT_EXTRACTION_PASSES=1
DATASETS_LANGEXTRACT_TIMEOUT=600000
# Number of items the langextract Python helper batches per Gemini call.
DATASETS_LANGEXTRACT_BATCH_LENGTH=60

# -------------------------------------------
# Materials Detection (Google Gemini)
# -------------------------------------------
MATERIALS_DETECTION_ENABLED=false
MATERIALS_DETECTION_GEMINI_API_KEY=your_gemini_api_key
MATERIALS_DETECTION_GEMINI_MODEL=gemini-2.5-flash
MATERIALS_DETECTION_API_TIMEOUT=300000
MATERIALS_DETECTION_DEMO_DATA_ENABLED=true

# -------------------------------------------
# Protocols Detection (Google Gemini)
# -------------------------------------------
PROTOCOLS_DETECTION_ENABLED=false
PROTOCOLS_DETECTION_GEMINI_API_KEY=your_gemini_api_key
PROTOCOLS_DETECTION_GEMINI_MODEL=gemini-2.5-flash
PROTOCOLS_DETECTION_API_TIMEOUT=300000
PROTOCOLS_DETECTION_DEMO_DATA_ENABLED=true

# -------------------------------------------
# KRT Comparison — AI suggestions (Google Gemini)
# Compares the author KRT vs the Generated KRT to produce add/update/remove
# suggestions. LM-only: with this disabled / no key, NO suggestions are produced.
# -------------------------------------------
KRT_COMPARISON_ENABLED=false
KRT_COMPARISON_GEMINI_API_KEY=your_gemini_api_key
KRT_COMPARISON_GEMINI_MODEL=gemini-2.5-flash
KRT_COMPARISON_API_TIMEOUT=300000

# -------------------------------------------
# Code/Software Detection (Softcite API)
# -------------------------------------------
SOFTCITE_API_ENABLED=false
SOFTCITE_API_BASE_URL=http://localhost:8050
SOFTCITE_API_TIMEOUT=600000
SOFTWARE_DETECTION_DEMO_DATA_ENABLED=true

# -------------------------------------------
# GROBID API (ORCID extraction)
# -------------------------------------------
GROBID_API_ENABLED=false
GROBID_API_BASE_URL=http://localhost:8070
GROBID_API_TIMEOUT=30000
ORCID_EXTRACTION_DEMO_DATA_ENABLED=false

# -------------------------------------------
# OpenAlex API (ORCID enrichment, free, no key needed)
# -------------------------------------------
OPENALEX_MAILTO=your-email@example.com
OPENALEX_API_TIMEOUT=10000
OPENALEX_API_ENABLED=true

# -------------------------------------------
# ORCID Public API (optional fallback)
# -------------------------------------------
ORCID_API_ENABLED=true
ORCID_API_TIMEOUT=5000

# -------------------------------------------
# Identifier Detection (local scan — no external API)
# -------------------------------------------
# Scans the converted markdown against the curated enrichment lists for known
# DOIs / RRIDs / accessions / catalog numbers. Pure in-process; no API key.
#
# Enable/disable the whole module. Defaults to enabled; set to 'false' to skip
# identifier detection entirely (the job then produces no data).
IDENTIFIER_DETECTION_ENABLED=true
# Truncate the document at the first "References"/"Bibliography" heading before
# scanning, so cited-paper DOIs don't create false positives. Defaults to 'true'.
# Set to 'false' to scan the WHOLE document — needed for combined manuscript +
# supplemental PDFs where the Key Resources table sits AFTER the references
# heading (some converters, e.g. Docling, emit "References" as a real heading).
IDENTIFIER_DETECTION_CUT_AT_REFERENCES=true

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# -------------------------------------------
# KRT
# -------------------------------------------
KRT_TEMPLATE_URL=https://docs.google.com/spreadsheets/d/YOUR_TEMPLATE_ID/edit
