[Unit]
Description=ASAP KR-Sync Application (Dev)
After=docker.service postgresql.service
Requires=docker.service

[Service]
Type=simple
Restart=always
RestartSec=10

ExecStartPre=-/usr/bin/docker stop asap-kr-sync-dev
ExecStartPre=-/usr/bin/docker rm asap-kr-sync-dev

ExecStart=/usr/bin/docker run --rm --name asap-kr-sync-dev \
  --add-host=host.docker.internal:host-gateway \
  --env-file /opt/asap-kr-sync-dev/.env \
  -e AWS_REGION=ca-central-1 \
  -e AUTH0_SECRET_ID=asap-kr-sync/dev/auth0 \
  -v /opt/asap-kr-sync-dev/credentials:/app/credentials:ro \
  -v /opt/asap-kr-sync-dev/backend/data:/app/src/backend/data:ro \
  -v /opt/asap-kr-sync-dev/src/frontend/public/demo-files:/app/src/frontend/public/demo-files:ro \
  -v /opt/asap-kr-sync-dev/logs:/app/logs \
  -p 127.0.0.1:3000:3000 \
  <ECR_REGISTRY>/asap-kr-sync:dev-latest

ExecStop=/usr/bin/docker stop asap-kr-sync-dev

[Install]
WantedBy=multi-user.target
