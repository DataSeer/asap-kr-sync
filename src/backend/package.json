{
  "name": "asap-kr-sync-backend",
  "version": "1.0.0",
  "description": "ASAP KR-Sync Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo:all",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop",
    "db:rebuild": "sequelize-cli db:drop; sequelize-cli db:create && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "test": "node --test services controllers middleware utils",
    "test:watch": "node --test --watch services controllers middleware utils",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/client-secrets-manager": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@google/genai": "^1.50.1",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fast-xml-parser": "^5.7.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "libreoffice-convert": "^1.8.1",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pg-boss": "^9.0.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.2",
    "uuid": "^11.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
